# CMake build directories
# Note: `build/` is reserved for the cross-build Dockerfile + CMake toolchain
# file. Per-developer CMake build trees go in `_build/` (or anywhere matching
# the patterns below). See build/README.md for the canonical container-based
# build flow.
_build/
cmake-build-*/
CMakeCache.txt
CMakeFiles/

# Compiled objects
*.o
*.so
*.so.*
*.a

# Toolchain downloads
toolchain/

# Editor
.vscode/
*.swp
*~
.DS_Store

# Cross-build container artifact output
out/
